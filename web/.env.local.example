# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RIDB (https://ridb.recreation.gov -> profile -> API key)
RIDB_API_KEY=your-ridb-key

# Resend (https://resend.com -> API Keys)
RESEND_API_KEY=re_your_key
ALERT_FROM_EMAIL=alerts@yourdomain.com

# Random string; Vercel cron sends it as Bearer token to /api/cron/poll
CRON_SECRET=generate-a-long-random-string

# Affiliate link wrappers (optional). After enrolling in the Hipcamp (AvantLink)
# and KOA affiliate programs, set these to your network's click-redirect PREFIX
# ending in "...&url=" — the destination URL gets appended + encoded. Leave blank
# for plain (non-commission) referral links.
NEXT_PUBLIC_HIPCAMP_AFFILIATE_WRAP=
NEXT_PUBLIC_KOA_AFFILIATE_WRAP=
